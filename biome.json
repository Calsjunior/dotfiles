{
    "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "html": {
        "formatter": {
            "enabled": true,
            "whitespaceSensitivity": "ignore",
            "attributePosition": "auto",
            "lineWidth": 90
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "useSortedProperties": "on",
                "useSortedAttributes": "on"
            }
        }
    }
}
