{
    "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
    "root": false,
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 160
    },
    "html": {
        "formatter": {
            "enabled": true,
            "bracketSameLine": true,
            "whitespaceSensitivity": "ignore",
            "attributePosition": "auto",
            "lineWidth": 90
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    }
}
